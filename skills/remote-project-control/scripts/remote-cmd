#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  remote-cmd [--dry-run] <ssh-alias> <remote-dir> -- <command> [args...]

Run a simple argv-style command on a server after cd'ing into <remote-dir>.
Shell metacharacters are quoted as literal arguments. For loops, pipes,
variables, globs, find/awk pipelines, or multi-line logic, use remote-bash.
USAGE
}

dry_run=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      dry_run=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      echo "remote-cmd: missing ssh alias and remote directory before --" >&2
      usage >&2
      exit 2
      ;;
    *)
      break
      ;;
  esac
done

if [[ $# -lt 4 ]]; then
  usage >&2
  exit 2
fi

host=$1
remote_dir=$2
shift 2

if [[ "${1:-}" != "--" ]]; then
  echo "remote-cmd: expected -- before remote command" >&2
  usage >&2
  exit 2
fi
shift

if [[ $# -eq 0 ]]; then
  echo "remote-cmd: missing remote command" >&2
  usage >&2
  exit 2
fi

shell_quote() {
  printf '%q' "$1"
}

remote_command="cd $(shell_quote "$remote_dir") && exec"
for arg in "$@"; do
  remote_command+=" $(shell_quote "$arg")"
done

if [[ "$dry_run" -eq 1 ]]; then
  printf 'ssh %s %s\n' "$(shell_quote "$host")" "$(shell_quote "$remote_command")"
  exit 0
fi

exec ssh "$host" "$remote_command"
